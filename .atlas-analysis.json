  "keyFeatures": [
    "Plugin Manager with one-click install, update, activate/deactivate, version history, and WP.org search",
    "Theme Manager with activation, upload, export, and version history from WordPress.org",
    "Monaco Editor-powered File Manager with full filesystem browser and syntax highlighting",
    "Database Manager with table browser, row CRUD, search & replace, SQL runner, and export",
    "User Manager with role management, username rename, and admin impersonation via secure tokens",
    "Maintenance Mode with gradient presets, countdown timer, emoji picker, and live preview",
    "Security Suite: admin URL protection, login attempt limiter, IP blocklist, 2FA, and core integrity check",
    "Security Scanner with malware detection, WPScan vulnerability API, SSL monitor, and security score",
    "Agency Tools: mail interceptor, white-label login page, admin UI customiser, client report generator, coming soon mode",
    "Developer Utilities: hook explorer, REST API tester, dummy data generator, rewrite rules tester, object cache browser, DB prefix changer",
    "Image Tools with WebP/AVIF conversion, batch processing, thumbnail regeneration, and SVG upload support",
    "Cron Manager with event scheduling, custom schedules, manual triggers, and health monitoring",
    "Media Manager for orphaned, unused, and duplicate media cleanup with compression tools",
    "Code Snippets runner for PHP, CSS, and JavaScript with Monaco Editor",
    "Database Backup with scheduled backups, download, and WP Cron integration"
  ],
